# Meshtastic ↔ Telegram Relay — template .env.
# Copy this to .env and fill in values (or use the GUI).

# --- Connection ---
BOT_TOKEN=PASTE_BOT_TOKEN_HERE
OWNER_ID=0
POCKET_NODE_ID=""
LAST_COM_PORT=""
DISPLAY_NAME=Михаил
NODE_MODEL=generic
MESH_HOP_LIMIT=1
MESH_DELIVERY_MODE=reliable

# --- Limits ---
MAX_TEXT_LENGTH=170
SLOT_TTL_HOURS=20
SLOT_STICKY_HOURS=10
MAX_USERNAME_IN_PREFIX=10
POCKET_FRESH_MIN=10
POCKET_STALE_MIN=60

# --- GPS (BETA — not tested by author) ---
GPS_ENABLED=false
GPS_FIX_FRESH_MIN=5
GPS_FIX_STALE_MIN=30
GPS_FIX_MAX_MIN=120
WHERE_RATE_LIMIT_MIN=5

# --- Access ---
WHITELIST_ENABLED=false

# --- SOS ---
SOS_ENABLED=false
SOS_MESSAGE="🆘 Михаилу нужна помощь. Это автоматическое уведомление."
SOS_INCLUDE_COORDS=true
SOS_RECIPIENTS=

# --- Delivery / retry ---
RETRY_INITIAL_DELAY_MIN=2
RETRY_MAX_INTERVAL_MIN=15

# --- Logging ---
LOG_FILE_ENABLED=true
LOG_FILE_MAX_MB=5
LOG_FILE_KEEP=5

# --- AI helper (LM Studio / Ollama / OpenAI-compatible) ---
AI_ENABLED=false
AI_BASE_URL=http://localhost:1234/v1
AI_API_KEY=lm-studio
AI_MODEL=llama-3.2-8b-instruct
AI_SYSTEM_PROMPT="Отвечай коротко и ясно. Максимум 2-3 предложения. Без лишних объяснений и приветствий."
AI_TIMEOUT_SEC=30
AI_MAX_HISTORY=10
AI_TTL_HOURS=168
